{
  "name": "parkly",
  "version": "1.0.0",
  "scripts": {

    "server": "node server/index.js",
    "client": "npm run dev --prefix frontend",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "client": "npm run dev --prefix frontend",
    "server": "nodemon server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.8",
    "express-session": "^1.19.0"
  }
}
